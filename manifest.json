{
  "manifest_version": 3,
  "name": "Runway Auto Generator",
  "version": "1.0.0",
  "description": "Runway ML Generate 버튼이 활성화되면 자동으로 클릭해주는 확장 프로그램",
  "permissions": [
    "notifications",
    "alarms",
    "storage",
    "debugger",
    "tabs"
  ],
  "host_permissions": [
    "https://app.runwayml.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.runwayml.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Runway Auto Generator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}